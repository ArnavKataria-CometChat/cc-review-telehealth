# ---------------------------------------------------------------------------
# Web portal configuration (Next.js). Copy to `.env.local` for local dev.
# ---------------------------------------------------------------------------

# Base URL of the telehealth backend API (the ../backend service).
# The client calls `${NEXT_PUBLIC_API_BASE_URL}/api/...`.
# NOTE: NEXT_PUBLIC_* values are inlined at BUILD time. When building the Docker
# image, pass this as a build arg (see Dockerfile / README).
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Phase B (CometChat) — no web env vars required.
#
# The web client holds NO CometChat config or secrets. On login it calls the
# backend's `POST /api/cometchat/token`, which returns { uid, authToken, appId,
# region }; the client inits the SDK with that App ID + Region and logs in with
# the backend-issued auth token. All CometChat credentials (App ID, Region, Auth
# Key, and the server-only REST API Key) live in the ../backend environment.
# ---------------------------------------------------------------------------
