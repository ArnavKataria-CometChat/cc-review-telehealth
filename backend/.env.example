# ---- Server ----
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (frontends). Use * for any.
CORS_ORIGIN=*

# ---- Auth ----
# Secret used to sign session JWTs. MUST be overridden in production.
JWT_SECRET=dev-only-change-me
# Token lifetime, e.g. 15m, 12h, 7d
JWT_EXPIRES_IN=12h
# bcrypt cost factor for password hashing
BCRYPT_ROUNDS=10

# Password used for all seeded demo accounts (see README).
SEED_PASSWORD=Passw0rd!

# ---------------------------------------------------------------------------
# Phase B — CometChat. Copy this file to `.env` (gitignored) and fill in real
# values from the CometChat dashboard. NEVER commit real credentials.
#
#   COMETCHAT_APP_ID / COMETCHAT_REGION  — safe to hand to clients (App ID + Region).
#   COMETCHAT_AUTH_KEY                    — client/dev convenience key; not used by
#                                           the backend token flow.
#   COMETCHAT_REST_API_KEY               — SERVER ONLY (fullAccess scope). Mints
#                                           auth tokens + creates/updates users.
#                                           Must never appear in a client bundle.
#
# If these are left empty the backend still builds and runs; the CometChat routes
# respond 503 ("not configured") until the values are provided.
# ---------------------------------------------------------------------------
COMETCHAT_APP_ID=
COMETCHAT_REGION=us
COMETCHAT_AUTH_KEY=
COMETCHAT_REST_API_KEY=
